{
  "name": "mause/laravel-arca",
  "description": "Laravel package scaffold for AFIP/ARCA integrations.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "ext-soap": "*",
    "ext-openssl": "*",
    "ext-simplexml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "autoload": {
    "psr-4": {
      "Mause\\LaravelArca\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mause\\LaravelArca\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mause\\LaravelArca\\LaravelArcaServiceProvider"
      ],
      "aliases": {
        "Arca": "Mause\\LaravelArca\\Facades\\Arca"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
